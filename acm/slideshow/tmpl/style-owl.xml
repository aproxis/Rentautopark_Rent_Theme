<?xml version="1.0" encoding="utf-8"?>
<form>
  <title>Slideshow Style 1</title>
  <sampledata><![CDATA[ 
	{":type":"uber:slideshow"}
   ]]>
 </sampledata>
  <fields name="slideshow">
    <fieldset name="basic" label="SLIDESHOW_BASIC_LABEL" description="SLIDESHOW_BASIC_DESC" multiple="0"> 
      
      <field name="navigation" type="radio" default="1" label="SLIDESHOW_NAVIGATION_BUTTONS_LABEL" description="SLIDESHOW_NAVIGATION_BUTTONS_DESC" >
        <option value="1" class="on">JYES</option>
        <option value="0" class="off">JNO</option>
      </field>
      
      <field name="pagination" type="radio" default="1" label="SLIDESHOW_PAGINATION_BUTTONS_LABEL" description="SLIDESHOW_PAGINATION_BUTTONS_DESC" >
        <option value="1" class="on">JYES</option>
        <option value="0" class="off">JNO</option>
      </field>
      
    </fieldset>
		
		<fieldset name="basic2" label="SLIDESHOW_BASIC_2_LABEL" description="SLIDESHOW_BASIC_2_DESC" multiple="1">

				<field name="title" type="text" 
					description="SLIDESHOW_TITLE_DES"
					label="SLIDESHOW_TITLE"
					default=""
					/>
					
				<field name="description" type="textarea" 
					description="SLIDESHOW_DESCRIPTIONS_DES"
					label="SLIDESHOW_DESCRIPTIONS_TITLE"
					default=""
					/>

				<field name="image" type="media" 
					description="SLIDESHOW_IMG_DES"
					label="SLIDESHOW_IMG_TITLE"
					default=""
					/>

				<field name="button" type="text" 
					description="SLIDESHOW_BTN_DES"
					label="SLIDESHOW_BTN_TITLE"
					default=""
					/>

				<field name="button-link" type="text" 
					description="SLIDESHOW_BTN_LINK_DES"
					label="SLIDESHOW_BTN_LINK_TITLE"
					default=""
					/>

		</fieldset>
  </fields>
</form>