<?xml version="1.0" encoding="utf-8"?>
<form>
    <title>Hero</title>

    <fields name="hero">

        <!-- ── Content ──────────────────────────────────────────── -->
        <fieldset name="content" label="Content">

            <field
                name="bg-image"
                type="media"
                label="Background Image"
                description="Path to the hero background image (e.g. images/backgrounds/hero.jpg)"
                default="images/backgrounds/hero.jpg"
            />

            <field
                name="heading"
                type="text"
                label="Heading"
                description="Main hero headline"
                default="Fast booking, delivery and 24/7 support"
            />

            <field
                name="subheading"
                type="textarea"
                label="Subheading"
                description="Short description shown below the headline"
                rows="3"
                default="Professional car rental services for personal or business needs."
            />

            <field
                name="choose-car-url"
                type="text"
                label="Choose Car URL"
                description="URL for the primary CTA button (relative or absolute)"
                default="cars"
            />

            <field
                name="choose-car-label"
                type="text"
                label="Choose Car Button Label"
                default="Choose a car"
            />

            <field
                name="call-btn-label"
                type="text"
                label="Call Button Label"
                default="Sună acum"
            />

        </fieldset>

        <!-- ── Social proof ─────────────────────────────────────── -->
        <fieldset name="social" label="Social Proof">

            <field
                name="people-count"
                type="text"
                label="People Count"
                description="Displayed next to the client avatar stack (e.g. 1000+ people)"
                default="1000+ people"
            />

            <field
                name="promo-text"
                type="text"
                label="Promo Text"
                description="Text that follows the people count"
                default="chose to rent cars from Rent AutoPark"
            />

            <field
                name="client-photo"
                type="jalist"
                label="Client Photos"
                description="Repeatable list of client avatar images"
            >
                <fields>
                    <field
                        name="photo"
                        type="media"
                        label="Photo"
                        description="Client avatar (square crop recommended)"
                    />
                </fields>
            </field>

        </fieldset>

        <!-- ── Stats labels ─────────────────────────────────────── -->
        <fieldset name="stats" label="Stats Widgets">

            <field
                name="cars-available-label"
                type="text"
                label="Cars Available Label"
                description="Label shown under the live car count widget"
                default="Cars available"
            />

            <field
                name="price-note"
                type="text"
                label="Price Note"
                description="Small note shown under the minimum price widget"
                default="More days, lower price"
            />

        </fieldset>

        <!-- ── Contact links ────────────────────────────────────── -->
        <fieldset name="contact" label="Contact Links">

            <field
                name="phone-link"
                type="text"
                label="Phone Link"
                description="tel: link used for the Phone messenger button (e.g. tel:+37300000000)"
                default=""
            />

            <field
                name="whatsapp-link"
                type="text"
                label="WhatsApp Link"
                description="Full WhatsApp URL (e.g. https://wa.me/37300000000)"
                default=""
            />

            <field
                name="telegram-link"
                type="text"
                label="Telegram Link"
                description="Full Telegram URL (e.g. https://t.me/username)"
                default=""
            />

            <field
                name="viber-link"
                type="text"
                label="Viber Link"
                description="Full Viber URL (e.g. viber://chat?number=37300000000)"
                default=""
            />

        </fieldset>

    </fields>
</form>